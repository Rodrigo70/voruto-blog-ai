# ── SEGREDOS — adicione estes no GitHub: Settings → Secrets and variables → Actions ──

# Anthropic (obrigatório)
ANTHROPIC_API_KEY=sk-ant-...

# Sanity write token (obrigatório)
# Sanity Studio → Manage → API → Tokens → Add API token (Editor)
SANITY_API_TOKEN=sk...

# WordPress Application Password (obrigatório)
# WP Admin → Usuários → voruto-blog-bot → Senhas de aplicativo
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# eBay Browse API — OAuth com App ID + Cert ID (Client Secret)
# Painel: developer.ebay.com → Application Keys → Production
EBAY_APP_ID=Rodrigo-...
EBAY_CERT_ID=

# PokémonTCG.io API Key (opcional — sem key funciona com rate limit menor)
# Obter em: https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# Heritage Auctions: bloqueia acesso automatizado (403), removido do pipeline.
# Dados de leilões cobertos pelo eBay findCompletedItems (sold listings).

# ── CONFIGURAÇÕES PÚBLICAS — já definidas no workflow, não precisam ir aqui ──

SANITY_PROJECT_ID=cuj6jfyx
SANITY_DATASET=production
WP_URL=https://voruto.com.br
WP_USER=voruto-blog-bot

# ── DESENVOLVIMENTO LOCAL ──
# Para rodar localmente: copie este arquivo para .env e preencha os valores
# python scripts/generate_post.py
# Temas disponíveis para TOPIC_OVERRIDE:
#   lancamentos-tcg | leiloes-mercado | collabs-cultura
#   guia-colecionador | curiosidades-raridades | mercado-global
TOPIC_OVERRIDE=
